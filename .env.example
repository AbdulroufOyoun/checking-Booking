# =============================================================================
# Hotel System — copy to .env on server, then fill values marked CHANGE_ME
# Local:  cp .env.example .env && php artisan key:generate
# Prod:   set APP_DEBUG=false, APP_URL=api subdomain, FRONTEND_URL=app subdomain
# =============================================================================

APP_NAME="Hotel System"
APP_ENV=production
APP_KEY=base64:UmqofxSMFNDG6sunX5DZjEdysNKuYO8WYuFmlgIAWu4=
APP_DEBUG=false
APP_URL=https://hotelsystemback.osus.network

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=error

# -----------------------------------------------------------------------------
# Primary database (reservations, rooms, users, accounting, …)
# cPanel: use localhost (not 127.0.0.1) if connection fails
# -----------------------------------------------------------------------------
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=osusnetw_hotelsystem
DB_USERNAME=osusnetw_abd
DB_PASSWORD=abd0988929807@

# -----------------------------------------------------------------------------
# Secondary database — Client model uses connection "mysql2"
# On shared hosting you may use the SAME database as DB_* above if all tables
# are in one MySQL database; otherwise create a second DB and fill DB2_*.
# -----------------------------------------------------------------------------
DB2_HOST=localhost
DB2_PORT=3306
DB2_DATABASE=osusnetw_hotelUsers
DB2_USERNAME=osusnetw_abd
DB2_PASSWORD=abd0988929807@

# -----------------------------------------------------------------------------
# Angular frontend URL (CORS) — must match app subdomain exactly (https)
# Example: https://app.yourdomain.com
# -----------------------------------------------------------------------------
FRONTEND_URL=https://hotelsystem.osus.network

BROADCAST_DRIVER=log
CACHE_DRIVER=file
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=120

# Optional: set true on HTTPS production
SESSION_SECURE_COOKIE=true

# Production: set strong password then run php artisan hotel:ensure-admin
# HOTEL_ADMIN_PASSWORD=

# -----------------------------------------------------------------------------
# API rate limits (requests per minute)
# Authenticated SPA users need a higher ceiling (property page loads many endpoints).
# -----------------------------------------------------------------------------
API_RATE_LIMIT_AUTHENTICATED=600
API_RATE_LIMIT_GUEST=120
API_RATE_LIMIT_LOGIN=20

# -----------------------------------------------------------------------------
# Demo / seed (run locally before upload, or via Remote MySQL)
# DEMO_LIGHT=1          → smaller seed (recommended for first deploy)
# DEMO_SEED=1           → set by demo:setup command only
# SEED_RESERVATIONS_FRESH=0
# -----------------------------------------------------------------------------

# -----------------------------------------------------------------------------
# Reports (shared-host cron: php artisan reports:process-pending --limit=5)
# -----------------------------------------------------------------------------
REPORT_PAGE_SIZE=50
REPORT_PREVIEW_LIMIT=500
REPORT_EXPORT_RETENTION_DAYS=7
REPORT_MAX_PENDING_PER_USER=3

# -----------------------------------------------------------------------------
# Mail — required only for email report delivery
# cPanel: use your domain SMTP or host's mail server
# -----------------------------------------------------------------------------
MAIL_MAILER=smtp
MAIL_HOST=abdulroufoyoun@osus.network
MAIL_PORT=587
MAIL_USERNAME=noreply@osus.network
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="noreply@osus.network"
MAIL_FROM_NAME="${APP_NAME}"
# -----------------------------------------------------------------------------
# Local development overrides (uncomment for XAMPP / artisan serve)
# -----------------------------------------------------------------------------
# APP_ENV=local
# APP_DEBUG=true
# APP_URL=http://127.0.0.1:8001
# FRONTEND_URL=http://127.0.0.1:4200
# DB_HOST=127.0.0.1
# DB_DATABASE=hotel_booking
# DB_USERNAME=root
# DB_PASSWORD=
# DB2_HOST=127.0.0.1
# DB2_DATABASE=clientCheckinBooking
# DB2_USERNAME=root
# DB2_PASSWORD=
# LOG_LEVEL=debug
# MAIL_MAILER=smtp
# MAIL_HOST=mailpit
# MAIL_PORT=1025
# MAIL_USERNAME=null
# MAIL_PASSWORD=null
# MAIL_ENCRYPTION=null
# MAIL_FROM_ADDRESS=hello@example.com
